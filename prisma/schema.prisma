// Learn more about Prisma schema: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Tenancy
// Tenant is included from the start to support future multi-tenancy.
// All users belong to a Tenant. In the current single-tenant deployment,
// there is one default Tenant row. tenantId is nullable on User so that
// existing records survive the migration; it will be made required once
// multi-tenancy is actively enforced.
// ---------------------------------------------------------------------------

model Tenant {
  id                 String   @id @default(cuid())
  name               String
  createdAt          DateTime @default(now())
  profilePermissions Json?    // ProfilePermissions: which fields customer users may self-edit

  users             User[]
  customerCompanies CustomerCompany[]
  documentTemplates DocumentTemplate[]
}

// ---------------------------------------------------------------------------
// Users
// Consultancy staff and customer users share this model for authentication.
// Customer-role users (Customer Admin / Customer User) link to a
// CustomerCompany via customerCompanyId.
// ---------------------------------------------------------------------------

model User {
  id                String   @id @default(cuid())
  email             String?  @unique // null for no-email workers who sign off via kiosk
  displayName       String
  passwordHash      String?           // null for no-email workers (no login possible)
  role              String   @default("Customer User")
  jobRole           String?  // freeform job role string used for assignment filtering
  lineManagerId     String?           // no-email workers point to their manager for email routing
  createdAt         DateTime @default(now())
  tenantId          String? // null = default single-tenant; required when multi-tenancy is enforced
  customerCompanyId String? // null for consultancy staff; required for customer-role users

  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  customerCompany CustomerCompany? @relation(fields: [customerCompanyId], references: [id])
  lineManager     User?            @relation("LineManagement", fields: [lineManagerId], references: [id])
  directReports   User[]           @relation("LineManagement")
  passwordReset   PasswordReset?
  completions     CompletionRecord[]
  userAssignments Assignment[]     @relation("UserAssignment")
}

// ---------------------------------------------------------------------------
// Password resets
// One token per user at a time; expires after 1 hour.
// ---------------------------------------------------------------------------

model PasswordReset {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [email], references: [email])
}

// ---------------------------------------------------------------------------
// Document model
// templates → assignments → completions
// ---------------------------------------------------------------------------

// A client business served by the consultancy.
model CustomerCompany {
  id         String   @id @default(cuid())
  name       String
  tenantId   String?
  folderPath String? // blob storage folder path; auto-set on creation
  createdAt  DateTime @default(now())

  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  users       User[]
  assignments Assignment[]
}

// A reusable H&S document maintained by the consultancy.
// blobPath is the path to the template file in Azure Blob Storage; nullable
// because form-based templates may not have a backing file initially.
// formSchema is a JSON array of FormField objects (see src/types/form-schema.ts)
// that defines the fields the customer must fill in to complete this template.
model DocumentTemplate {
  id          String   @id @default(cuid())
  title       String
  description String?
  blobPath    String? // path in Azure Blob Storage; null for form-only templates
  formSchema  Json? // array of FormField; null means no form fields defined
  questions   Json? // array of ComprehensionQuestion; null means no questions defined
  tenantId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  assignments Assignment[]
}

// Links a DocumentTemplate to a CustomerCompany (company-wide) or to a specific
// User within a company (individual). userId = null means all users in the company
// can see it; userId set means only that user sees it.
// Uniqueness is enforced via two partial indexes in the database migration:
//   - (templateId, customerCompanyId) WHERE userId IS NULL  (one company-wide assignment per template)
//   - (templateId, userId) WHERE userId IS NOT NULL          (one individual assignment per user per template)
model Assignment {
  id                String    @id @default(cuid())
  templateId        String
  customerCompanyId String
  userId            String?   // null = company-wide; set = individual user
  dueDate           DateTime? // optional deadline; null = no due date
  targetJobRoles    Json?     // string[] of job roles that can see this assignment; null = visible to all
  createdAt         DateTime  @default(now())

  template        DocumentTemplate @relation(fields: [templateId], references: [id])
  customerCompany CustomerCompany  @relation(fields: [customerCompanyId], references: [id])
  user            User?            @relation("UserAssignment", fields: [userId], references: [id])
  completions     CompletionRecord[]
}

// A customer user's signed completion of an assigned document.
// blobPath is nullable — PDF generation is a future step; for now a
// completion is recorded as an audit trail entry only.
// formData stores structured form responses for future Document Intelligence.
model CompletionRecord {
  id           String   @id @default(cuid())
  assignmentId String
  signedById   String // User.id of the signer
  signedAt     DateTime @default(now())
  blobPath     String? // path to signed PDF in Azure Blob Storage; null until PDF generation is built
  formData     Json? // structured form data; populated when Document Intelligence is added

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  signedBy   User       @relation(fields: [signedById], references: [id])
}
